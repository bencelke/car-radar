# Firebase (optional — app runs in mock mode without these)
# All six vars must be set for Firestore writes (e.g. /submit → collection "submissions").
# Copy to .env.local — never commit .env.local.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Mapbox (optional — /map uses mock fallback without token)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
