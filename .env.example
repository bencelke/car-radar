# Copy to .env.local — never commit .env.local (gitignored).
#
# Firebase Console → your project → Project settings → General → Your apps → Web app
# Copy the full firebaseConfig object. All six core vars must be from the SAME web app.
#
# Validate locally:
#   npm run firebase:check
#   npm run dev:check-env

# --- Firebase Web SDK (required) ---
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# --- Optional: Firebase Analytics (not wired in app yet) ---
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Mapbox (optional — /map shows fallback without it) ---
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token_here

# --- Site origin for share/invite links (set in production) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Optional: Facebook login visibility (true | false) ---
NEXT_PUBLIC_FACEBOOK_AUTH_ENABLED=

# --- Server-only / local dev (DO NOT use NEXT_PUBLIC_ prefix) ---
# Path to Firebase Admin service account JSON — local scripts + API routes only.
# Never commit the JSON file. See docs/firebase-admin-dev-setup.md
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-service-account.json

# Fallback for dev scripts only (optional if NEXT_PUBLIC_FIREBASE_PROJECT_ID is set)
# FIREBASE_PROJECT_ID=your_project_id
